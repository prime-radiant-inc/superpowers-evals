#!/usr/bin/env bash
# Verify the Codex native-hooks backend used an isolated trusted plugin hook.
set -euo pipefail

fail() {
    echo "FAIL: $*"
    exit 1
}

pass() {
    echo "PASS: Codex native Superpowers hook configured"
    exit 0
}

# Shared between Drill and Harness: accept either framework's workdir var.
WORKDIR="${HARNESS_WORKDIR:-${DRILL_WORKDIR:-}}"

# Codex home: Drill exports DRILL_CODEX_HOME; the harness seeds the per-run
# home at agent-config/ inside the run dir (the assertion's cwd).
CODEX_HOME_DIR="${DRILL_CODEX_HOME:-}"
if [ -z "$CODEX_HOME_DIR" ] && [ -d agent-config ]; then
    CODEX_HOME_DIR="agent-config"
fi
test -n "$CODEX_HOME_DIR" || fail "no Codex home (DRILL_CODEX_HOME unset, no agent-config/)"
test -n "$WORKDIR" || fail "neither HARNESS_WORKDIR nor DRILL_WORKDIR is set"

CONFIG="$CODEX_HOME_DIR/config.toml"
PLUGIN="$CODEX_HOME_DIR/plugins/cache/debug/superpowers/local"

test -f "$CONFIG" || fail "missing Codex config at $CONFIG"
test -f "$PLUGIN/.codex-plugin/plugin.json" || fail "missing staged Codex plugin manifest"
# Check the run-hook.cmd wrapper, not the hook-config JSON: Superpowers
# renamed hooks-codex.json to hooks.json; run-hook.cmd is the stable part.
test -f "$PLUGIN/hooks/run-hook.cmd" || fail "missing staged Codex hook runner"
test ! -e "$WORKDIR/.agents/skills/superpowers" || fail "legacy .agents skill symlink exists"

grep -Fq "plugin_hooks = true" "$CONFIG" || fail "plugin_hooks feature not enabled"
grep -Fq '[plugins."superpowers@debug"]' "$CONFIG" || fail "debug Superpowers plugin not enabled"
# Match the trust-state key's stable shape — don't pin the config-file
# segment of the key, which moved from hooks-codex.json to hooks.json.
grep -Eq 'hooks\.state\."superpowers@debug:[^"]*session_start' "$CONFIG" \
    || fail "Superpowers Codex hook trust state missing"
grep -Eq 'trusted_hash = "sha256:[a-f0-9]+"' "$CONFIG" || fail "trusted hook hash missing"

pass
