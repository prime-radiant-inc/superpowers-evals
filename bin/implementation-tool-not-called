#!/usr/bin/env bash
# Pass iff a tool was not called on implementation files.
#
# This is intentionally narrower than `tool-not-called`: agents may update
# harness/private artifacts, docs/superpowers specs, or workspace setup files
# without "jumping into implementation code".
_RECORD_CHECK=implementation-tool-not-called
_RECORD_ARGS=("$@")
source "$(dirname "$0")/_record"
set -uo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

TOOL="$1"
FILE="${QUORUM_TOOL_CALLS_PATH:-coding-agent-tool-calls.jsonl}"

if [ ! -s "$FILE" ]; then
    record_fail "tool-calls file missing or empty"
    exit 1
fi

COUNT=$(
    jq -L "$(dirname "$0")" -s --arg tool "$TOOL" \
        'include "_implementation_path";
         [.[] | select(.tool == $tool and is_implementation_path)] | length' \
        "$FILE"
)

FIRST_PATH=$(
    jq -L "$(dirname "$0")" -r -s --arg tool "$TOOL" \
        'include "_implementation_path";
         [.[] | select(.tool == $tool and is_implementation_path) | implementation_relpath]
         | first // ""' \
        "$FILE"
)

if [ "$COUNT" -eq 0 ]; then
    record_pass "no implementation $TOOL call"
else
    record_fail "implementation $TOOL called $COUNT time(s); first path: $FIRST_PATH"
    exit 1
fi
