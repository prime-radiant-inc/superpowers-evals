#!/usr/bin/env bash
# Rebuild fixtures/skeleton-codex-home/ — the logged-in state the harness
# copies into each per-run CODEX_HOME so codex boots straight to the prompt
# instead of the "Welcome to Codex / Sign in" auth picker.
#
# Without this skeleton the harness seeds an empty CODEX_HOME, codex reports
# "Not logged in", and every run burns QA-agent turns dismissing the picker
# before codex self-heals from $OPENAI_API_KEY. Seeding a valid auth.json
# skips the picker entirely. This is the codex twin of
# refresh-skeleton-claude-home.
#
# auth.json holds the raw OPENAI_API_KEY, so the skeleton is gitignored —
# every machine rebuilds its own. Run this once with OPENAI_API_KEY set;
# re-run whenever the key rotates.
set -euo pipefail

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            sed -n '2,14p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *) echo "unknown arg: $1" >&2; exit 2 ;;
    esac
done

[ -n "${OPENAI_API_KEY:-}" ] || { echo "OPENAI_API_KEY not set" >&2; exit 1; }
command -v codex >/dev/null || { echo "codex CLI required" >&2; exit 127; }

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DEST="$REPO_ROOT/fixtures/skeleton-codex-home"

rm -rf "$DEST"
mkdir -p "$DEST"

printenv OPENAI_API_KEY | CODEX_HOME="$DEST" codex login --with-api-key

# Confirm the seed took — a logged-in home is what suppresses the picker.
CODEX_HOME="$DEST" codex login status

echo "Wrote $DEST"
ls -la "$DEST"
