#!/usr/bin/env bash
# Verify a specific Skill was invoked before the first implementation-file
# call of a named tool.
#
# Usage: skill-before-implementation-tool <skill-name> <tool-name>
_RECORD_CHECK=skill-before-implementation-tool
_RECORD_ARGS=("$@")
source "$(dirname "$0")/_record"
set -uo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

SKILL_NAME="$1"
SKILL_DIR="${SKILL_NAME##*:}"
TOOL_NAME="$2"
FILE="${QUORUM_TOOL_CALLS_PATH:-coding-agent-tool-calls.jsonl}"

if [ ! -s "$FILE" ]; then
    record_fail "tool-calls file missing or empty"
    exit 1
fi

SKILL_IDX=$(
    jq -L "$(dirname "$0")" -s \
        --arg name "$SKILL_NAME" --arg dir "$SKILL_DIR" \
        'include "_skill_predicate";
         to_entries | map(select(.value | is_skill_invocation($name; $dir)))
         | first | (.key // -1)' \
        "$FILE"
)

TOOL_IDX=$(
    jq -L "$(dirname "$0")" -s --arg tool "$TOOL_NAME" \
        'include "_implementation_path";
         to_entries
         | map(select(.value.tool == $tool and (.value | is_implementation_path)))
         | first | (.key // -1)' \
        "$FILE"
)

TOOL_PATH=$(
    jq -L "$(dirname "$0")" -r -s --arg tool "$TOOL_NAME" \
        'include "_implementation_path";
         [
           .[]
           | select(.tool == $tool and is_implementation_path)
           | implementation_relpath
         ]
         | first // ""' \
        "$FILE"
)

if [ "$TOOL_IDX" -lt 0 ]; then
    record_pass "no implementation $TOOL_NAME call — assertion is vacuous"
    exit 0
fi

if [ "$SKILL_IDX" -lt 0 ]; then
    record_fail "implementation $TOOL_NAME fired at line $((TOOL_IDX + 1)) ($TOOL_PATH) but Skill($SKILL_NAME) never fired"
    exit 1
fi

if [ "$SKILL_IDX" -lt "$TOOL_IDX" ]; then
    record_pass "Skill($SKILL_NAME) at line $((SKILL_IDX + 1)) before implementation $TOOL_NAME at line $((TOOL_IDX + 1)) ($TOOL_PATH)"
else
    record_fail "Skill($SKILL_NAME) at line $((SKILL_IDX + 1)) fired after implementation $TOOL_NAME at line $((TOOL_IDX + 1)) ($TOOL_PATH)"
    exit 1
fi
