#!/usr/bin/env bash
# Verify a specific superpowers Skill was NOT invoked.
#
# Usage: skill-not-called <skill-name>
# Example: skill-not-called superpowers:brainstorming
#
# Inverse of skill-called — passes when the skill never fired. Used by
# cost scenarios that measure skill over-triggering. Detection mirrors
# skill-called: a Skill tool call OR a shell command reading the skill's
# SKILL.md both count as "called".
_RECORD_CHECK=skill-not-called
_RECORD_ARGS=("$@")
source "$(dirname "$0")/_record"
set -uo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

SKILL_NAME="$1"
SKILL_DIR="${SKILL_NAME##*:}"
FILE="${QUORUM_TOOL_CALLS_PATH:-coding-agent-tool-calls.jsonl}"

# A negative assertion can't be verified without a transcript: an empty/missing
# capture means "we don't know", not "the skill wasn't called". Fail rather than
# vacuously pass (mirrors implementation-tool-not-called).
if [ ! -s "$FILE" ]; then
    record_fail "tool-calls file missing or empty"
    exit 1
fi

COUNT=$(
    jq -L "$(dirname "$0")" -s \
        --arg name "$SKILL_NAME" --arg dir "$SKILL_DIR" \
        'include "_skill_predicate";
         [.[] | select(is_skill_invocation($name; $dir))] | length' \
        "$FILE" 2>/dev/null || echo 0
)

if [ "$COUNT" -eq 0 ]; then
    record_pass "Skill($SKILL_NAME) never called"
else
    record_fail "Skill($SKILL_NAME) called $COUNT time(s) (expected 0)"
    exit 1
fi
