#!/usr/bin/env bash
# quorum-generated launcher for Claude Code (the agent under test).
#
# The cd, Claude auth env, throwaway-$HOME pin, plugin-dir, and flags are baked
# in here so the QA agent launches Claude with ONE token and cannot skip the
# prepared workdir. quorum substitutes the $… values below at runtime, so the
# installed copy contains literal absolute paths (no env inheritance needed —
# tmux strips env from new sessions).
#
# No CLAUDE_CONFIG_DIR is set: the launcher pins HOME to the throwaway home via
# $QUORUM_HOME_ENV, and provisioning seeds the config INTO <HOME>/.claude
# (claude.yaml home_config_subdir: ".claude"). Claude finds its config and
# writes its transcript under its $HOME/.claude default, so the config dir need
# not be threaded through the launcher.
#
# Host-env isolation (PRI-2494): `env -i` + explicit allowlist, matching the
# opencode/serf launchers. Host ANTHROPIC_BASE_URL / ANTHROPIC_AUTH_TOKEN /
# CLAUDE_CODE_* feature flags must not reconfigure the agent under test. env -i
# supersedes the old `-u CLAUDECODE -u CLAUDE_CODE_SESSION_ID` nested-session
# strips: nothing survives that is not listed here. Any host-inherited
# Bedrock/AWS/gate vars, and ANTHROPIC_API_KEY, are unset before
# $CLAUDE_ENV_FILE is sourced, so the gate and the values below come only from
# the run-scoped env file, never host inheritance — see the Mantle note below.
#
# CLAUDE_CODE_FORCE_SESSION_PERSISTENCE=1 is the authoritative override — it
# forces transcript persistence regardless of nested-session detection (e.g.
# CLAUDE_CODE_CHILD_SESSION), so capture stays robust across claude versions.
# Claude Code (>=2.1.166) skips writing its session transcript when it detects a
# nested interactive session; this override lets the eval run from inside a
# Claude Code session while the agent under test still persists its transcript
# (so capture sees real tool calls). If capture ever comes back empty anyway,
# claude is a strict-capture target, so the run is a loud
# indeterminate(stage=capture), never a silent pass.
#
# Equivalent manual command (for debugging):
#   cd "$QUORUM_AGENT_CWD" && source "$CLAUDE_ENV_FILE" && env -i PATH="$PATH" TERM="${TERM:-xterm-256color}" LANG="${LANG:-C.UTF-8}" HOME="$QUORUM_AGENT_HOME" TMPDIR="<…>" XDG_DATA_HOME="<…>" XDG_CONFIG_HOME="<…>" XDG_STATE_HOME="<…>" XDG_CACHE_HOME="<…>" CLAUDE_CODE_FORCE_SESSION_PERSISTENCE=1 ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY" claude --dangerously-skip-permissions --plugin-dir "$SUPERPOWERS_ROOT" --model "$CLAUDE_MODEL"
#
# Auth is either ANTHROPIC_API_KEY (direct API) or CLAUDE_CODE_USE_MANTLE +
# AWS_REGION + AWS_BEARER_TOKEN_BEDROCK (Bedrock/Mantle), whichever
# $CLAUDE_ENV_FILE set, plus provision()'s API-key approval; the project-trust
# block provision() writes into .claude.json suppresses the trust prompt. No
# onboarding skeleton, IS_DEMO, or marketplace-disable is needed — claude boots
# headless and runs/auto-completes onboarding each run (that is what activates
# auth). (IS_DEMO=1 is NOT used: it skips that first-run flow on a never-onboarded
# config, so claude comes up "Not logged in" — reproduced 2/2. The auth resolver
# itself is IS_DEMO-independent; it's the onboarding-skip on a fresh config that
# bites.)
set -euo pipefail
cd "$QUORUM_AGENT_CWD" || { echo "launch-agent: cannot cd to $QUORUM_AGENT_CWD" >&2; exit 1; }
# Scrub any host-inherited Bedrock/AWS/gate vars, and ANTHROPIC_API_KEY, BEFORE
# sourcing, so the gate and values below come ONLY from the run-scoped
# .claude-env, never host inheritance (PRI-2494). The forward list further down
# MUST stay a subset of this unset list.
unset CLAUDE_CODE_USE_MANTLE CLAUDE_CODE_USE_BEDROCK \
  AWS_REGION AWS_DEFAULT_REGION AWS_BEARER_TOKEN_BEDROCK \
  AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN AWS_PROFILE \
  ANTHROPIC_API_KEY
source "$CLAUDE_ENV_FILE"

# Host-env isolation (PRI-2494): env -i + explicit allowlist, matching the
# opencode/serf launchers. Host ANTHROPIC_BASE_URL / ANTHROPIC_AUTH_TOKEN /
# CLAUDE_CODE_* feature flags must not reconfigure the agent under test.
env_args=(
  "PATH=${PATH:-/usr/bin:/bin:/usr/sbin:/sbin}"
  "TERM=${TERM:-xterm-256color}"
  "LANG=${LANG:-C.UTF-8}"
)

# Bedrock/Mantle: forwarded ONLY when the sourced .claude-env set them (the
# Bedrock credential path). provision writes all three together, so referencing
# them here under set -u is safe. Subset of the unset list above.
if [[ -n "${CLAUDE_CODE_USE_MANTLE:-}" ]]; then
  env_args+=("CLAUDE_CODE_USE_MANTLE=$CLAUDE_CODE_USE_MANTLE")
  env_args+=("AWS_REGION=$AWS_REGION")
  env_args+=("AWS_BEARER_TOKEN_BEDROCK=$AWS_BEARER_TOKEN_BEDROCK")
fi

# Direct-API key: forwarded ONLY on the api-key path (the Mantle path omits it, so
# the unconditional line would abort under set -u). ANTHROPIC_API_KEY was unset
# before the source above, so this value can only have come from .claude-env,
# never host inheritance (PRI-2494).
if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
  env_args+=("ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY")
fi

exec env -i \
  "${env_args[@]}" \
  $QUORUM_HOME_ENV \
  CLAUDE_CODE_FORCE_SESSION_PERSISTENCE=1 \
  claude --dangerously-skip-permissions --plugin-dir "$SUPERPOWERS_ROOT" --model "$CLAUDE_MODEL" "$@"
