#!/usr/bin/env bash
# quorum-generated launcher for Codex (the agent under test).
#
# The cd and the bypass flag are baked in here so the QA agent launches Codex
# with ONE token and cannot accidentally skip the `cd` or shorten the command.
# That skip was the qa-agent-misconfigured failure mode: Codex launched from the
# scratch dir, rollouts landed off-workdir, and the run was discarded. quorum
# substitutes the $… values below at runtime, so the installed copy contains
# literal absolute paths (no env inheritance needed — tmux strips env from new
# sessions).
#
# Host-env isolation (PRI-2494): `env -i` + explicit allowlist, matching the
# opencode/serf launchers. Supersedes the old targeted -u OPENAI_* scrubs:
# nothing survives that is not listed here. CODEX_PROVIDER_API_KEY is forwarded
# only when the api-key path's env file set it; the subscription path
# authenticates from $HOME/.codex/auth.json under the throwaway home.
#
# Equivalent manual command (for debugging):
#   subscription path:
#     cd "$QUORUM_AGENT_CWD" && env -i PATH="$PATH" TERM="${TERM:-xterm-256color}" LANG="${LANG:-C.UTF-8}" HOME="$QUORUM_AGENT_HOME" TMPDIR="<…>" XDG_DATA_HOME="<…>" XDG_CONFIG_HOME="<…>" XDG_STATE_HOME="<…>" XDG_CACHE_HOME="<…>" codex --dangerously-bypass-approvals-and-sandbox
#   api-key path (CODEX_ENV_FILE written by provision):
#     . "$CODEX_ENV_FILE" && cd "$QUORUM_AGENT_CWD" && env -i PATH="$PATH" TERM="${TERM:-xterm-256color}" LANG="${LANG:-C.UTF-8}" HOME="$QUORUM_AGENT_HOME" TMPDIR="<…>" XDG_DATA_HOME="<…>" XDG_CONFIG_HOME="<…>" XDG_STATE_HOME="<…>" XDG_CACHE_HOME="<…>" CODEX_PROVIDER_API_KEY="$CODEX_PROVIDER_API_KEY" codex --dangerously-bypass-approvals-and-sandbox
#
# CODEX_HOME collapse: this launcher sets HOME (via $QUORUM_HOME_ENV) but NOT
# CODEX_HOME. Codex defaults CODEX_HOME to $HOME/.codex, which is exactly where
# the runner seeds the per-run config (auth.json + the trusted plugin hook) —
# so Codex finds its config via the isolated $HOME with no config-dir var.
#
# HOME isolation: Codex discovers user-scope skills and plugin marketplaces from
# $HOME/.agents/{skills,plugins}, resolved via $HOME directly (codex core-skills
# loader adds an "$HOME/.agents/skills" user skill root via home_dir(), with no
# off switch). Left at the host's HOME, a host ~/.agents/skills/* symlink (e.g.
# into a host superpowers checkout) bleeds host skills into the run and overrides
# the staged superpowers@debug plugin. The shared $QUORUM_HOME_ENV pins HOME (and
# XDG/TMPDIR) to the per-run throwaway home every agent uses, forcing Codex to
# load the staged skills — the version actually under test. Codex auth lives in
# $HOME/.codex/auth.json (seeded by the runner), so isolating HOME does not
# affect login; the scenario repo carries local git identity, so commits are
# unaffected.
#
# Api-key path: when provision writes codex-api.env (api-key credential), the
# runner substitutes $CODEX_ENV_FILE with the absolute path. Source it
# conditionally so the subscription path (no file) is unaffected. The sourced
# file exports CODEX_PROVIDER_API_KEY, which codex reads as the custom
# provider's env_key.
set -euo pipefail
cd "$QUORUM_AGENT_CWD" || { echo "launch-agent: cannot cd to $QUORUM_AGENT_CWD" >&2; exit 1; }

[ -f "$CODEX_ENV_FILE" ] && . "$CODEX_ENV_FILE"

# Host-env isolation (PRI-2494): env -i + explicit allowlist, matching the
# opencode/serf launchers. Supersedes the old targeted -u OPENAI_* scrubs:
# nothing survives that is not listed here. CODEX_PROVIDER_API_KEY is
# forwarded only when the api-key path's env file set it; the subscription
# path authenticates from $HOME/.codex/auth.json under the throwaway home.
env_args=(
  "PATH=${PATH:-/usr/bin:/bin:/usr/sbin:/sbin}"
  "TERM=${TERM:-xterm-256color}"
  "LANG=${LANG:-C.UTF-8}"
)
if [[ -n "${CODEX_PROVIDER_API_KEY-}" ]]; then
  env_args+=("CODEX_PROVIDER_API_KEY=$CODEX_PROVIDER_API_KEY")
fi

exec env -i \
  "${env_args[@]}" \
  $QUORUM_HOME_ENV \
  codex --dangerously-bypass-approvals-and-sandbox "$@"
