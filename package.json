{
  "name": "quorum",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "quorum": "./src/cli/index.ts",
    "evals-appliance": "./src/appliance/cli.ts"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "workspaces": [
    "packages/dashboard"
  ],
  "scripts": {
    "quorum": "bun run src/cli/index.ts",
    "appliance": "bun run src/appliance/cli.ts",
    "dashboard": "bun packages/dashboard/src/index.ts",
    "test": "bun test test/",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome ci . && tsc --noEmit && bun test test/ && cd packages/dashboard && bun run check",
    "build": "bun build src/cli/index.ts --compile --outfile dist/quorum"
  },
  "dependencies": {
    "@primeradianthq/obol": "^0.7.0",
    "commander": "^12",
    "yaml": "^2",
    "zod": "^3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@types/bun": "latest",
    "typescript": "^5.9"
  }
}
